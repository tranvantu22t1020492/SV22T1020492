@model IEnumerable<SV22T1020492.Models.Sales.Order>
@{
    ViewBag.Title = "Lịch sử mua hàng";
    int currentStatus = ViewBag.CurrentStatus ?? 0;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 0;
    string searchValue = ViewBag.SearchValue ?? "";
}

<style>
    /* ===== HEADER BOX ===== */
    .order-header {
        background: linear-gradient(135deg, #eef5ff, #f8fbff);
        border-radius: 20px;
    }

    /* ===== SEARCH ===== */
    .search-box input {
        border-radius: 50px;
        padding-left: 20px;
    }

    .search-box button {
        border-radius: 50px;
    }

    /* ===== FILTER ===== */
    .nav-pills .nav-link {
        border-radius: 50px;
        padding: 6px 18px;
        transition: 0.25s;
        font-size: 14px;
    }

        .nav-pills .nav-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    /* ===== ORDER CARD ===== */
    .order-card {
        border-radius: 18px;
        transition: 0.3s;
        background: #fff;
    }

        .order-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    .order-id {
        font-size: 18px;
        letter-spacing: 1px;
    }

    /* ===== STATUS BADGE ===== */
    .badge {
        padding: 6px 12px;
        font-size: 12px;
        border-radius: 20px;
        letter-spacing: 0.5px;
    }

    /* ===== BUTTON ===== */
    .btn-detail {
        border-radius: 30px;
        transition: 0.25s;
    }

        .btn-detail:hover {
            background: #0d6efd;
            color: #fff;
            transform: scale(1.05);
        }

    /* ===== PAGINATION ===== */
    .pagination .page-link {
        border-radius: 10px;
        margin: 0 3px;
        transition: 0.2s;
    }

        .pagination .page-link:hover {
            background: #0d6efd;
            color: #fff;
        }

    /* ===== EMPTY ===== */
    .empty-box {
        border-radius: 20px;
        background: linear-gradient(135deg, #f8f9fa, #eef2f7);
    }
</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="order-header p-4 shadow-sm mb-4 text-center border">
        <h3 class="fw-bold mb-4 text-primary">ĐƠN HÀNG CỦA BẠN</h3>

        <!-- SEARCH -->
        <form action="/Order/Index" method="get" class="mx-auto mb-4 search-box" style="max-width: 500px;">
            <input type="hidden" name="status" value="@currentStatus" />
            <div class="input-group shadow-sm overflow-hidden">
                <input type="text" name="searchValue" class="form-control border-0"
                       placeholder="🔍 Tìm kiếm đơn hàng..." value="@searchValue">
                <button class="btn btn-primary px-4" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>

        <!-- FILTER -->
        <div class="d-flex justify-content-center overflow-auto py-2">
            <div class="nav nav-pills flex-nowrap">
                <a class="nav-link mx-1 @(currentStatus == 0 ? "active bg-dark text-white" : "text-dark border")"
                   href="/Order/Index?status=0&searchValue=@searchValue">Tất cả</a>

                <a class="nav-link mx-1 @(currentStatus == 1 ? "active bg-info text-white" : "text-dark border")"
                   href="/Order/Index?status=1&searchValue=@searchValue">Chờ duyệt</a>

                <a class="nav-link mx-1 @(currentStatus == 2 ? "active bg-primary text-white" : "text-dark border")"
                   href="/Order/Index?status=2&searchValue=@searchValue">Đã duyệt</a>

                <a class="nav-link mx-1 @(currentStatus == 3 ? "active bg-warning text-dark" : "text-dark border")"
                   href="/Order/Index?status=3&searchValue=@searchValue">Đang giao</a>

                <a class="nav-link mx-1 @(currentStatus == 4 ? "active bg-success text-white" : "text-dark border")"
                   href="/Order/Index?status=4&searchValue=@searchValue">Hoàn tất</a>
            </div>
        </div>
    </div>

    <!-- LIST ORDER -->
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="card order-card mb-3 border-0 shadow-sm">
                <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap">

                    <!-- LEFT -->
                    <div>
                        <div class="fw-bold text-primary order-id mb-1">
                            #@item.OrderID
                        </div>

                        <div class="text-muted small mb-2">
                            <i class="far fa-clock me-1"></i>
                            @item.OrderTime.ToString("dd/MM/yyyy HH:mm")
                        </div>

                        <!-- ===== STATUS ===== -->
                        <div class="mb-2">
                            @switch ((int)item.Status)
                            {
                                case 1:
                                    <span class="badge bg-info">Chờ duyệt</span>
                                    break;
                                case 2:
                                    <span class="badge bg-primary">Đã duyệt</span>
                                    break;
                                case 3:
                                    <span class="badge bg-warning text-dark">Đang giao</span>
                                    break;
                                case 4:
                                    <span class="badge bg-success">Hoàn tất</span>
                                    break;
                                case -1:
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                                case -2:
                                    <span class="badge bg-secondary">Bị từ chối</span>
                                    break;
                                default:
                                    <span class="badge bg-dark">Không xác định</span>
                                    break;
                            }
                        </div>

                        <div class="small">
                            <i class="fas fa-map-marker-alt text-danger me-2"></i>
                            @item.DeliveryAddress
                        </div>
                    </div>

                    <!-- RIGHT -->
                    <div class="mt-3 mt-md-0">
                        <a href="/Order/Details/@item.OrderID"
                           class="btn btn-outline-primary btn-detail px-4">
                            <i class="fas fa-eye me-1"></i>Chi tiết
                        </a>
                    </div>

                </div>
            </div>
        }

        <!-- PAGINATION -->
        @if (totalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">

                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="/Order/Index?page=@(currentPage - 1)&status=@currentStatus&searchValue=@searchValue">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link shadow-sm"
                               href="/Order/Index?page=@i&status=@currentStatus&searchValue=@searchValue">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link"
                           href="/Order/Index?page=@(currentPage + 1)&status=@currentStatus&searchValue=@searchValue">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>

                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5 empty-box shadow-sm border">
            <i class="fas fa-box-open fa-2x text-muted mb-3"></i>
            <p class="text-muted mb-0">Bạn chưa có đơn hàng nào.</p>
        </div>
    }

</div>