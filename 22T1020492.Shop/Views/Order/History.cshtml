@model IEnumerable<SV22T1020492.Models.Sales.Order>
@{
    ViewBag.Title = "Lịch sử mua hàng";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 border-bottom">
        <h4 class="mb-0 fw-bold text-secondary">
            <i class="fas fa-history me-2"></i>LỊCH SỬ MUA HÀNG
        </h4>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Ngày hoàn tất</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.OrderID</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(item.FinishedTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>
                                    @if ((int)item.Status == 4)
                                    {
                                        <span class="badge bg-success-soft text-success border border-success px-3">Thành công</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border px-3">Đã hủy</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Order/Details/@item.OrderID" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="p-3 border-top">
                    <ul class="pagination pagination-sm mb-0 justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="/Order/History?page=@i&searchValue=@ViewBag.SearchValue">@i</a>
                            </li>
                        }
                    </ul>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-folder-open fa-3x text-light mb-3"></i>
                <h5 class="text-muted">Bạn chưa có đơn hàng nào trong lịch sử</h5>
                <a href="/" class="btn btn-primary mt-3 rounded-pill px-4">Mua sắm ngay</a>
            </div>
        }
    </div>
</div>