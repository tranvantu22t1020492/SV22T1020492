@model SV22T1020492.Models.Sales.OrderDetail
@{
    Layout = null;
}
<div class="modal-header">
    <strong class="modal-title">Cập nhật chi tiết đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <form action="~/Order/UpdateCartItem" method="post" class="container-fluid">
        @* Các input ẩn để giữ ID đơn hàng và ID sản phẩm *@
        <input type="hidden" name="OrderID" value="@Model.OrderID" />
        <input type="hidden" name="ProductID" value="@Model.ProductID" />

        <div class="row">
            <div class="col-md-8">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">Mặt hàng</label>
                    <div class="col-sm-8">
                        @* Hiển thị tên (giả định bạn đã lấy được ProductName từ Service) *@
                        <input type="text" class="form-control-plaintext fw-bold"
                               value="@ViewBag.ProductName" readonly>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">Số lượng</label>
                    <div class="col-sm-5">
                        <input type="number" name="Quantity"
                               class="form-control text-end"
                               min="1" value="@Model.Quantity">
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">Đơn giá</label>
                    <div class="col-sm-5">
                        <input type="text" name="SalePrice"
                               class="form-control text-end money-input"
                               value="@Model.SalePrice.ToString("N0")">
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-end">
                <img src="/images/products/@(ViewBag.Photo ?? "no-image.png")"
                     class="img-thumbnail" style="max-height:150px">
            </div>
        </div>

        <div class="modal-footer px-0 pb-0">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        </div>
    </form>
</div>