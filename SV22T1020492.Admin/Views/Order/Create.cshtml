@model IEnumerable<SV22T1020492.Models.Catalog.Product>
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <div class="col-md-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-search"></i> Lựa chọn hàng cần bán</h5>
            </div>

            <div class="card-body">
                <form id="formSearchProduct" action="@Url.Action("SearchProduct", "Order")" method="get" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               name="searchValue"
                               id="searchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary" type="button" onclick="doSearch()">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <div id="searchProductResult" style="height: 600px; overflow-y: auto;">
                    @Html.Partial("SearchProduct", Model)
                </div>
            </div>

            <div class="card-footer text-center">
                <small class="text-muted">Sử dụng thanh cuộn để xem thêm sản phẩm</small>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-outline card-success mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-cart"></i> Danh sách mặt hàng đã chọn</h5>
            </div>
            <div class="card-body">
                <div id="cart-container">
                </div>
                <div class="text-end border-top pt-2">
                    <button type="button" onclick="clearCart()" class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i> Xóa giỏ hàng
                    </button>
                </div>
            </div>
        </div>

        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person"></i> Thông tin khách hàng & nơi giao hàng</h5>
            </div>
            <div class="card-body">
                <form method="post" action="@Url.Action("InitOrder", "Order")">
                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label text-end">Khách hàng</label>
                        <div class="col-md-10">
                            <input type="text" name="CustomerName" class="form-control" placeholder="Nhập tên khách hàng..." required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label text-end">Tỉnh/thành</label>
                        <div class="col-md-10">
                            <select name="DeliveryProvince" class="form-select select2" required>
                                <option value="">-- Chọn Tỉnh/thành giao hàng --</option>
                                @foreach (var item in await SV22T1020492.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                                {
                                    <option value="@item.ProvinceName">@item.ProvinceName</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label text-end">Địa chỉ</label>
                        <div class="col-md-10">
                            <textarea name="DeliveryAddress" class="form-control" rows="2" placeholder="Số nhà, tên đường..."></textarea>
                        </div>
                    </div>

                    <div class="text-end border-top pt-3">
                        <button type="submit" class="btn btn-lg btn-primary">
                            <i class="bi bi-check-circle"></i> Lập đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <script>
        $(document).ready(function () {
            // Tự động load giỏ hàng khi nạp trang
            loadCart();

            // Hỗ trợ nhấn Enter trong ô tìm kiếm
            $("#searchValue").on("keypress", function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    doSearch();
                }
            });
        });

        // HÀM TÌM KIẾM SẢN PHẨM (Xử lý lỗi nút Search bấm không ăn)
        function doSearch() {
            var url = $("#formSearchProduct").attr("action");
            var searchTerm = $("#searchValue").val();

            $("#searchProductResult").html('<div class="text-center mt-4"><div class="spinner-border text-primary"></div><p>Đang tìm kiếm...</p></div>');

            $.ajax({
                url: url,
                type: "GET",
                data: { searchValue: searchTerm },
                success: function (res) {
                    $("#searchProductResult").html(res);
                },
                error: function () {
                    alert("Lỗi khi tải danh sách sản phẩm.");
                }
            });
        }

        function loadCart() {
            $("#cart-container").load("@Url.Action("GetCart", "Order")");
        }

        // HÀM THÊM VÀO GIỎ (Phải dùng trong SearchProduct.cshtml cho nút Thêm)
        function ajaxAddToCart(form) {
            var dto = {
                ProductID: parseInt($(form).find("input[name='ProductID']").val()) || 0,
                ProductName: $(form).find("input[name='ProductName']").val(),
                Photo: $(form).find("input[name='Photo']").val(),
                Unit: $(form).find("input[name='Unit']").val(),
                // Đảm bảo lấy giá trị số, thay thế dấu phẩy nếu có (định dạng VN)
                SalePrice: parseFloat($(form).find("input[name='SalePrice']").val().replace(',', '.')) || 0,
                Quantity: parseInt($(form).find("input[name='Quantity']").val()) || 1
            };

            if (dto.ProductID <= 0) {
                alert("Sản phẩm không hợp lệ");
                return;
            }

            $.ajax({
                url: "@Url.Action("AddToCart", "Order")",
                type: "POST",
                data: dto,
                success: function (html) {
                    $("#cart-container").html(html);
                },
                error: function (xhr) {
                    // Xem lỗi chi tiết từ Server trả về
                    console.error(xhr.responseText);
                    alert("Không thể thêm vào giỏ: " + xhr.responseText);
                }
            });
        }

        // HÀM XÓA TỪNG MẶT HÀNG TRONG GIỎ
        function removeFromCart(id) {
            if (confirm("Xóa mặt hàng này khỏi giỏ?")) {
                $.post("@Url.Action("RemoveFromCart", "Order")", { id: id }, function (html) {
                    $("#cart-container").html(html);
                });
            }
        }

        // HÀM XÓA SẠCH GIỎ HÀNG
        function clearCart() {
            if (confirm("Bạn có chắc muốn xóa toàn bộ giỏ hàng?")) {
                $.post("@Url.Action("ClearCart", "Order")", function (html) {
                    $("#cart-container").html(html);
                });
            }
        }
    </script>
}