@model IEnumerable<SV22T1020492.Models.Catalog.Product>
@{
    Layout = null;
}

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <form onsubmit="return false;" class="border rounded p-2 mb-2 bg-light shadow-sm">
            <input type="hidden" name="ProductID" value="@item.ProductID" />
            <input type="hidden" name="ProductName" value="@item.ProductName" />
            <input type="hidden" name="Photo" value="@item.Photo" />
            <input type="hidden" name="Unit" value="@item.Unit" />

            <strong class="text-primary d-block mb-1">@item.ProductName</strong>

            <div class="row">
                <div class="col-4">
                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "demo.png" : item.Photo)"
                         class="img-fluid border rounded" style="height:80px; width:100%; object-fit:cover" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="mb-0 small">Giá bán</label>
                            <input name="SalePrice" class="form-control form-control-sm text-end" value="@item.Price.ToString("0")" />
                        </div>
                        <div class="col-5">
                            <label class="mb-0 small">SL</label>
                            <input type="number" name="Quantity" min="1" value="1" class="form-control form-control-sm text-center" />
                        </div>
                    </div>
                    <button type="button" onclick="ajaxAddToCart(this.form)" class="btn btn-sm btn-primary mt-2 w-100">
                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }
}
else
{
    <div class="alert alert-warning text-center">Không có mặt hàng phù hợp.</div>
}