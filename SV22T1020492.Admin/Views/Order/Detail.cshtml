@model SV22T1020492.Models.Sales.OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    <div class="btn-group">
        @* Menu Xử lý đơn hàng chỉ hiện khi đơn chưa hoàn tất hoặc chưa bị từ chối *@
        @if (Model.Status != OrderStatusEnum.Completed && Model.Status != OrderStatusEnum.Rejected)
        {
            <button type="button"
                    class="btn btn-primary dropdown-toggle"
                    data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i>
                Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="~/Order/Cancel/@Model.OrderID" onclick="return confirm('Hủy đơn hàng sẽ xóa hoàn toàn đơn này khỏi hệ thống. Xác nhận?')">Hủy đơn hàng</a></li>
                }
                else if (Model.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="~/Order/Cancel/@Model.OrderID" onclick="return confirm('Hủy đơn hàng sẽ xóa hoàn toàn đơn này khỏi hệ thống. Xác nhận?')">Hủy đơn hàng</a></li>
                }
                else if (Model.Status == OrderStatusEnum.Shipping)
                {
                    <li><a class="dropdown-item" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="~/Order/Cancel/@Model.OrderID" onclick="return confirm('Hủy đơn hàng sẽ xóa hoàn toàn đơn này khỏi hệ thống. Xác nhận?')">Hủy đơn hàng</a></li>
                }
            </ul>
        }
    </div>

    @* Nút Xóa: Luôn hiển thị nếu đơn hàng ở trạng thái cho phép xóa (Mới, Từ chối, Hủy) *@
    @if (Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected)
    {
        <a href="~/Order/Delete/@Model.OrderID"
           class="btn btn-danger ms-1"
           onclick="return confirm('Xác nhận xóa vĩnh viễn đơn hàng này?')">
            <i class="bi bi-trash"></i>
            Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@* --- Phần hiển thị thông tin bên dưới giữ nguyên logic của bạn --- *@
<div class="alert alert-info d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong> @Model.StatusDescription
        @if (Model.FinishedTime.HasValue)
        {
            <span> lúc <b>@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></span>
        }
    </div>
</div>

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-receipt me-2"></i> Thông tin đơn hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.EmployeeName</div>
            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa duyệt")</div>
        </div>
    </div>
</div>

@* Thông tin khách hàng *@
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-person me-2"></i> Thông tin khách hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>
            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

@* Danh sách mặt hàng *@
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-box-seam me-2"></i> Danh sách mặt hàng</h5>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @{
                    int stt = 1;
                }
                @foreach (var item in Model.Details)
                {
                    <tr>
                        <td class="text-center">@(stt++)</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@((item.Quantity * item.SalePrice).ToString("N0"))</td>
                        <td class="text-end">
                            @* Chỉ cho sửa/xóa mặt hàng khi đơn mới *@
                            @if (Model.Status == OrderStatusEnum.New)
                            {
                                <a href="~/Order/EditCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-primary open-modal">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Order/DeleteCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-danger" onclick="return confirm('Xóa mặt hàng này?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@Model.Details.Sum(x => x.Quantity * x.SalePrice).ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
            padding: 5px 0;
        }

            .card-body .row:last-child {
                border-bottom: none;
            }
    </style>
}