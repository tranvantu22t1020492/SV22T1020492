@{
    ViewBag.Title = "Xóa Thuộc tính Mặt hàng";
    var productId = 123;
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10 col-sm-12">
        <div class="card card-danger">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Xác nhận xóa thuộc tính
                </h3>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle-fill me-1"></i>
                    Bạn đang chuẩn bị xóa thuộc tính sau.
                    <strong>Thao tác này không thể hoàn tác.</strong>
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-4">Mặt hàng</dt>
                    <dd class="col-sm-8">Trà sữa Trân châu</dd>

                    <dt class="col-sm-4">Tên thuộc tính</dt>
                    <dd class="col-sm-8">Thành phần</dd>

                    <dt class="col-sm-4">Giá trị</dt>
                    <dd class="col-sm-8">Trà đen, sữa tươi, trân châu đen, đường</dd>

                    <dt class="col-sm-4">Thứ tự</dt>
                    <dd class="col-sm-8">1</dd>
                </dl>
            </div>

            <div class="card-footer text-end">
                <a href="~/Product/ListAttributes/@productId" class="btn btn-secondary me-2">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash-fill"></i> Xác nhận xóa
                </button>
            </div>
        </div>
    </div>
</div>
