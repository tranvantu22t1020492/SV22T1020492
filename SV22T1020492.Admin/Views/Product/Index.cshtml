@model ProductSearchInput
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Product/Search" data-target="searchResult" onsubmit="productSearch(event, this, 1)">
            <input type="hidden" asp-for="PageSize" />
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select asp-for="CategoryID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @{
                            var categories = await SV22T1020492.BusinessLayers.CatalogDataService.ListCategoriesAsync(
                            new SV22T1020492.Models.Common.PaginationSearchInput { Page = 1, PageSize = 100, SearchValue = "" });
                            foreach (var c in categories.DataItems)
                            {
                                <option value="@c.CategoryID" selected="@(Model.CategoryID == c.CategoryID)">@c.CategoryName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select asp-for="SupplierID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @{
                            var suppliers = await PartnerDataService.ListSuppliersAsync(
                            new SV22T1020492.Models.Common.PaginationSearchInput { Page = 1, PageSize = 100, SearchValue = "" });
                            foreach (var s in suppliers.DataItems)
                            {
                                <option value="@s.SupplierID" selected="@(Model.SupplierID == s.SupplierID)">@s.SupplierName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text" id="inputMinPrice" name="MinPrice"
                               class="form-control money-input"
                               value=""
                               placeholder="Giá từ" />
                        <span class="input-group-text">-</span>
                        <input type="text" id="inputMaxPrice" name="MaxPrice"
                               class="form-control money-input"
                               value=""
                               placeholder="Giá đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text" asp-for="SearchValue" class="form-control" placeholder="Tên mặt hàng..." autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        function productSearch(event, form, page) {
            if (event) event.preventDefault();

            var minEl = document.getElementById("inputMinPrice");
            var maxEl = document.getElementById("inputMaxPrice");

            // Lấy giá trị số thực tế từ AutoNumeric
            var minVal = (minEl && AutoNumeric.isManagedByAutoNumeric(minEl))
                         ? parseFloat(AutoNumeric.getAutoNumericElement(minEl).getNumericString()) || 0 : 0;
            var maxVal = (maxEl && AutoNumeric.isManagedByAutoNumeric(maxEl))
                         ? parseFloat(AutoNumeric.getAutoNumericElement(maxEl).getNumericString()) || 0 : 0;

            // Gán lại giá trị thuần để gửi lên server
            if (minEl) minEl.value = minVal;
            if (maxEl) maxEl.value = maxVal;

            // --- KIỂM TRA ĐIỀU KIỆN ---
            if (event != null) {
                var minText = minEl.value.trim();
                var maxText = maxEl.value.trim();

                // 1. Cảnh báo nếu nhập giá âm
                if (minVal < 0 || maxVal < 0) {
                    alert("Giá tìm kiếm không được là số âm!");
                    return;
                }

                // 2. TRƯỜNG HỢP BẮT BUỘC: Nếu nhập "Giá từ" thì PHẢI nhập "Giá đến"
                // Kiểm tra dựa trên giá trị nhập vào thực tế (tránh trường hợp chỉ nhập 0)
                if (minVal > 0 && (maxText === "" || maxVal === 0)) {
                    alert("Vui lòng nhập 'Giá đến' khi đã chọn 'Giá từ'!");
                    maxEl.focus();
                    return;
                }

                // 3. Kiểm tra logic: Giá Từ > Giá Đến
                if (minVal > 0 && maxVal > 0 && minVal > maxVal) {
                    alert("Giá 'Từ' không được lớn hơn giá 'Đến'!");
                    minEl.focus();
                    return;
                }
            }

            // Nếu không nhập gì cả (cả 2 trống) thì vẫn cho tìm tất cả (692 mặt hàng)
            paginationSearch(event, form, page);
        }        
        document.addEventListener("DOMContentLoaded", function () {
            // Luôn tự động gọi tìm kiếm khi trang vừa load xong
            productSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}