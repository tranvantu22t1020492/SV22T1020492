@model List<ProductPhoto>
@{
    Layout = null;
    // ProductID được truyền từ controller hoặc từ view cha qua ViewBag
    int productID = ViewBag.ProductID;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <!-- id="photos" để anchor link #photos có thể cuộn đến -->
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                            <span class="badge bg-info ms-1">@Model.Count</span>
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@productID">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0 align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px;">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px;" class="text-center">Thứ tự</th>
                            <th style="width:120px;" class="text-center">Hiển thị</th>
                            <th style="width:100px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="~/images/products/@item.Photo"
                                         class="img-thumbnail"
                                         style="max-height:80px;"
                                         alt="@item.Description" />
                                </td>
                                <td>@item.Description</td>
                                <td class="text-center">@item.DisplayOrder</td>
                                <td class="text-center">
                                    @if (item.IsHidden)
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-eye-slash me-1"></i>Ẩn
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-eye me-1"></i>Hiện
                                        </span>
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    <a class="btn btn-sm btn-primary"
                                       href="~/Product/EditPhoto/@productID?photoId=@item.PhotoID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <!-- Xóa trực tiếp không qua confirm view -->
                                    <a class="btn btn-sm btn-danger"
                                       href="~/Product/DeletePhoto/@productID?photoId=@item.PhotoID">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted fst-italic">
                                    Mặt hàng chưa có ảnh nào
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>