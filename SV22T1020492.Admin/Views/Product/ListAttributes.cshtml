@model List<ProductAttribute>
@{
    Layout = null;
    // ProductID được truyền từ controller hoặc từ view cha qua ViewBag
    int productID = ViewBag.ProductID;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <!-- id="attributes" để anchor link #attributes có thể cuộn đến -->
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                            <span class="badge bg-success ms-1">@Model.Count</span>
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreateAttribute/@productID">
                            <i class="bi bi-plus"></i>
                            Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px;" class="text-center">Thứ tự</th>
                            <th style="width:100px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.AttributeName</td>
                                <td>@item.AttributeValue</td>
                                <td class="text-center">@item.DisplayOrder</td>
                                <td class="text-center text-nowrap">
                                    <a class="btn btn-sm btn-primary"
                                       href="~/Product/EditAttribute/@productID?attributeId=@item.AttributeID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <!-- Xóa trực tiếp không qua confirm view -->
                                    <a class="btn btn-sm btn-danger"
                                       href="~/Product/DeleteAttribute/@productID?attributeId=@item.AttributeID">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted fst-italic">
                                    Mặt hàng chưa có thuộc tính nào
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>